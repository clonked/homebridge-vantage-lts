{
  "name": "homebridge-vantage-lts",
  "version": "0.1.5",
  "description": "Vantage support for homebridge. Focused on long term support for modern node.",
  "type": "module",
  "license": "MIT",
    "keywords": [
    "homebridge-plugin"
  ],
  "main": "dist/index.js",
  "engines": {
    "node": ">=22.0.0",
    "homebridge": ">=2.0.0"
  },
  "author": {
    "name": "Nathan Anderson"
  },
  "repository": {
    "type": "git",
    "url": "https://github.com/clonked/homebridge-vantage"
  },
  "scripts": {
    "build": "rimraf ./dist && tsc",
    "lint": "eslint . --max-warnings=0",
    "prepublishOnly": "npm run lint && npm run build",
    "watch": "npm run build && npm link && nodemon"
  },
  "dependencies": {
    "@eslint/js": "^8.57.0 || ^9.0.0",
    "@types/node": "^25.6.0",
    "eslint": "^10.3.0",

    "nodemon": "^3.1.14",
    "rimraf": "^6.1.3",
    "ts-node": "^10.9.2",
    "typescript": "^6.0.3",
    "typescript-eslint": "^8.59.2",

    "homebridge-lib": "^8.0.1",
    "net": "latest",
    "sprintf-js": "latest",
    "xml2json": "latest",
    "libxmljs2": "latest",
    "wait-until": "latest",
    "promise": "latest",
    "debug": "latest",
    "inherits": "latest",
    "sleep": "latest"
  }
}
